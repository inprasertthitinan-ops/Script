local workspace = game:GetService("Workspace")
local players = game:GetService("Players")
local runService = game:GetService("RunService")
local replicatedStorage = game:GetService("ReplicatedStorage")
local localPlayer = players.LocalPlayer

local actionRemote = replicatedStorage:WaitForChild("Remotes"):WaitForChild("Action")

_G.AutoFarm = true
local skillDelay = 0.05
local questCheckInterval = 4 
local lastQuestTime = 0
local currentTargetRoot = nil
local lastNPCQuestIndex = 0 
local teleportConnection = nil

local function getPlayerLevel()
    local currentLevel = 1
    pcall(function()
        local playerGui = localPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            for _, gui in pairs(playerGui:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Enabled then
                    local frameDisplay = gui:FindFirstChild("Frame_Display", true)
                    if frameDisplay then
                        local levelTextObj = frameDisplay:FindFirstChild("LevelText", true)
                        if levelTextObj and levelTextObj:IsA("TextLabel") and levelTextObj.Text ~= "" then
                            local cleanNumber = string.gsub(levelTextObj.Text, "%D", "")
                            if cleanNumber and cleanNumber ~= "" then
                                currentLevel = tonumber(cleanNumber)
                            end
                        end
                    end
                end
            end
        end
    end)
    return currentLevel
end

local function getTargetNPC()
    local level = getPlayerLevel()
    local npcIndex = math.floor(level / 1000) + 1
    npcIndex = math.clamp(npcIndex, 1, 20)
    
    if npcIndex ~= lastNPCQuestIndex then
        currentTargetRoot = nil 
        lastNPCQuestIndex = npcIndex
    end
    
    local npcFolder = workspace:FindFirstChild("NpcQuest")
    if npcFolder then
        return npcFolder:FindFirstChild("NPC_Quest" .. tostring(npcIndex))
    end
    return nil
end

local function getToolAtSlot(slotIndex)
    local backpack = localPlayer:FindFirstChild("Backpack")
    local character = localPlayer.Character
    
    if character then
        local equippedTool = character:FindFirstChildOfClass("Tool")
        if equippedTool then
            return equippedTool
        end
    end
    
    if backpack then
        local toolItems = {}
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                table.insert(toolItems, item)
            end
        end
        return toolItems[slotIndex]
    end
    return nil
end

local function equipSelectedSlot()
    pcall(function()
        local character = localPlayer.Character
        if character then
            local alreadyEquipped = character:FindFirstChildOfClass("Tool")
            if not alreadyEquipped then
                local targetTool = getToolAtSlot(_G.SelectedSlot)
                if targetTool and targetTool.Parent ~= character then
                    character:FindFirstChildOfClass("Humanoid"):EquipTool(targetTool)
                end
            end
        end
    end)
end

-- Double-click/Double-fire interaction to force bypass old quests
local function interactWithNPC(npc)
    if not npc then return end
    local root = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChildOfClass("Part")
    if root and localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
        localPlayer.Character.HumanoidRootPart.CFrame = root.CFrame * CFrame.new(0, 0, -3)
        task.wait(0.1)
        
        local prompt = npc:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            fireproximityprompt(prompt)
            task.wait(0.15)
            fireproximityprompt(prompt) -- Double click to overwrite quest
        else
            local clickDetector = npc:FindFirstChildWhichIsA("ClickDetector", true)
            if clickDetector then
                fireclickdetector(clickDetector)
                task.wait(0.15)
                fireclickdetector(clickDetector) -- Double click to overwrite quest
            end
        end
        task.wait(0.15)
    end
end

local function useSkillRemote(skillKey)
    pcall(function()
        local targetTool = getToolAtSlot(_G.SelectedSlot)
        local toolName = targetTool and targetTool.Name or "Combat"
        
        local args = {
            toolName,
            skillKey
        }
        actionRemote:FireServer(unpack(args))
    end)
end

local function getClosestMobToNPC(npc)
    if not npc then return nil end
    local npcRoot = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChildOfClass("Part")
    if not npcRoot then return nil end

    local closestMob = nil
    local shortestDistance = math.huge
    local mobFolder = workspace:FindFirstChild("Mob")
    
    if mobFolder then
        for _, mob in pairs(mobFolder:GetChildren()) do
            local root = mob:FindFirstChild("HumanoidRootPart")
            local humanoid = mob:FindFirstChildOfClass("Humanoid")
            
            if root and (not humanoid or humanoid.Health > 0) then
                local distanceFromNPC = (npcRoot.Position - root.Position).Magnitude
                if distanceFromNPC < shortestDistance then
                    shortestDistance = distanceFromNPC
                    closestMob = root
                end
            end
        end
    end
    return closestMob
end

if teleportConnection then teleportConnection:Disconnect() end
teleportConnection = runService.Heartbeat:Connect(function()
    if _G.AutoFarm and currentTargetRoot and currentTargetRoot.Parent and localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local char = localPlayer.Character
        local root = char.HumanoidRootPart
        
        root.CFrame = (currentTargetRoot.CFrame * CFrame.new(0, 7, 0)) * CFrame.Angles(math.rad(-90), 0, 0)
        
        if not root:FindFirstChild("VelocityHandler") then
            local bv = Instance.new("BodyVelocity")
            bv.Name = "VelocityHandler"
            bv.Velocity = Vector3.new(0, 0, 0)
            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bv.Parent = root
        end
    else
        if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local bv = localPlayer.Character.HumanoidRootPart:FindFirstChild("VelocityHandler")
            if bv then bv:Destroy() end
        end
    end
end)

local function startFarm()
    task.spawn(function()
        while _G.AutoFarm do
            equipSelectedSlot()
            
            local currentNPC = getTargetNPC()
            
            if currentNPC and (tick() - lastQuestTime > questCheckInterval) then
                currentTargetRoot = nil 
                interactWithNPC(currentNPC)
                lastQuestTime = tick()
            end
            
            currentNPC = getTargetNPC()
            
            local targetMobRoot = getClosestMobToNPC(currentNPC)
            if targetMobRoot then
                currentTargetRoot = targetMobRoot
                
                local orderedSkills = {"Z", "X", "C", "V"}
                for _, skill in ipairs(orderedSkills) do
                    if not _G.AutoFarm or currentTargetRoot ~= targetMobRoot or getTargetNPC() ~= currentNPC then 
                        break 
                    end
                    
                    if _G.SelectedSkills[skill] then
                        useSkillRemote(string.lower(skill))
                        task.wait(skillDelay)
                    end
                end
            else
                currentTargetRoot = nil
                task.wait(0.05)
            end
            task.wait(0.01)
        end
    end)
end

ToggleButton.MouseButton1Click:Connect(function()
    _G.AutoFarm = not _G.AutoFarm
    if _G.AutoFarm then
        ToggleButton.Text = "STOP AUTOFARM"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        startFarm()
    else
        ToggleButton.Text = "START AUTOFARM"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        currentTargetRoot = nil
        if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local bv = localPlayer.Character.HumanoidRootPart:FindFirstChild("VelocityHandler")
            if bv then bv:Destroy() end
        end
    end
end)

startFarm()
