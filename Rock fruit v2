local function activateBuso() pcall(function() actionRemote:FireServer("Misc", "buso") end) end
local function getPlayerLevel()
    local lv = 1
    pcall(function()
        local data = localPlayer:FindFirstChild("Data") or replicatedStorage:FindFirstChild("PlayerData") and replicatedStorage.PlayerData:FindFirstChild(localPlayer.Name)
        if data and data:FindFirstChild("Level") then lv = data.Level.Value
        else local ls = localPlayer:FindFirstChild("leaderstats") if ls and ls:FindFirstChild("Level") then lv = ls.Level.Value end end
    end)
    return lv
end

local function getCurrentQuestConfig()
    local level = getPlayerLevel()
    for _, config in ipairs(questMap) do if level >= config.minLv and level <= config.maxLv then return config end end
    return questMap[1]
end

local function abandonCurrentQuest()
    pcall(function() cancelQuestRemote:FireServer("fire", [3] = "Quest", [4] = "Cancel") end)
    pcall(function()
        local frameQuest = localPlayer:FindFirstChild("PlayerGui") and localPlayer.PlayerGui:FindFirstChild("Frame_Quest", true)
        if frameQuest and frameQuest:FindFirstChild("Close_") then firesignal(frameQuest.Close_.MouseButton1Click) end
    end)
end

local function getTargetNPC() local config = getCurrentQuestConfig() return workspace:FindFirstChild("NpcQuest") and workspace.NpcQuest:FindFirstChild(config.npc) or nil end
local function getToolAtSlot(slot)
    if localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Tool") then return localPlayer.Character:FindFirstChildOfClass("Tool") end
    local bp = localPlayer:FindFirstChild("Backpack")
    if bp then local tools = {} for _, item in ipairs(bp:GetChildren()) do if item:IsA("Tool") then table.insert(tools, item) end end return tools[slot] end
    return nil
end

local function equipSelectedSlot()
    pcall(function()
        if localPlayer.Character and not localPlayer.Character:FindFirstChildOfClass("Tool") then
            local tool = getToolAtSlot(_G.SelectedSlot)
            if tool then localPlayer.Character:FindFirstChildOfClass("Humanoid"):EquipTool(tool) end
        end
    end)
end

local function interactWithNPC(npc, isNew)
    if not npc or not localPlayer.Character then return end
    local root = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChildOfClass("Part")
    local myRoot = localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root and myRoot then
        isProcessingQuest = true currentTargetRoot = nil
        myRoot.CFrame = root.CFrame * CFrame.new(0, 0, -3) task.wait(0.4)
        if isNew then abandonCurrentQuest() task.wait(2.0) end
        local prompt = npc:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then fireproximityprompt(prompt) else local cd = npc:FindFirstChildWhichIsA("ClickDetector", true) if cd then fireclickdetector(cd) end end
        task.wait(0.4) isProcessingQuest = false
    end
end

local function teleportOnceToIsland(targetPos)
    if _G.HasTeleportedToIsland then return end
    if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
        currentTargetRoot = nil
        localPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 15, 0))
        _G.HasTeleportedToIsland = true task.wait(2.5)
    end
end

local function getLockedMobTarget()
    local mobFolder = workspace:FindFirstChild("Mob") if not mobFolder then return nil end
    if _G.AutoKillBoss then
        for _, mob in pairs(mobFolder:GetChildren()) do
            if string.lower(mob.Name) == string.lower(_G.TargetBossToSummon) then
                local root = mob:FindFirstChild("HumanoidRootPart")
                local humanoid = mob:FindFirstChildOfClass("Humanoid")
                if root and (not humanoid or humanoid.Health > 0) then return root end
            end
        end
    end
    if _G.AutoMaterial and _G.SelectedMatMobs then
        for mobName, isSelected in pairs(_G.SelectedMatMobs) do
            if isSelected then
                local pos = matPositionMap[mobName] if pos then teleportOnceToIsland(pos) end
                for _, mob in pairs(mobFolder:GetChildren()) do
                    local isMatch = (mob.Name == mobName)
                    if mobName == "Bacon Minerals" then isMatch = (mob.Name == "Bacon Minerals" or mob.Name == "Bacon Kryptonite" or mob.Name == "Bacon Iron")
                    elseif mobName == "Bacon Lava" then isMatch = (mob.Name == "Bacon Lava" or mob.Name == "Bacon Hellfire") end
                    if isMatch then
                        local root = mob:FindFirstChild("HumanoidRootPart")
                        local humanoid = mob:FindFirstChildOfClass("Humanoid")
                        if root and (not humanoid or humanoid.Health > 0) then return root end
                    end
                end
            end
        end
    end
    if _G.AutoFarm then
        local config = getCurrentQuestConfig()
        if config then
            for _, mob in pairs(mobFolder:GetChildren()) do
                if mob.Name == config.mob then
                    local root = mob:FindFirstChild("HumanoidRootPart")
                    local humanoid = mob:FindFirstChildOfClass("Humanoid")
                    if root and (not humanoid or humanoid.Health > 0) then return root end
                end
            end
        end
    end
    return nil
end

