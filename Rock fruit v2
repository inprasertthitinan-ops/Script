_G.StartFarmLoopFunc = function()
    task.spawn(function()
        local firstConfig = getCurrentQuestConfig() if firstConfig then lastNpcTarget = firstConfig.npc end
        activateBuso()
        while _G.AutoFarm or _G.AutoMaterial or _G.AutoKillBoss do
            if not isProcessingQuest then
                equipSelectedSlot()
                if _G.AutoFarm and not _G.AutoMaterial and not _G.AutoKillBoss then
                    local config = getCurrentQuestConfig() local npc = getTargetNPC()
                    if npc and (tick() - lastQuestTime > questCheckInterval) then
                        local isNew = (config and config.npc ~= lastNpcTarget)
                        if config then lastNpcTarget = config.npc end
                        interactWithNPC(npc, isNew) lastQuestTime = tick()
                    end
                end
                local targetMobRoot = getLockedMobTarget()
                if targetMobRoot and not isProcessingQuest then
                    currentTargetRoot = targetMobRoot
                    local orderedSkills = {"Z", "X", "C", "V"}
                    for _, skill in ipairs(orderedSkills) do
                        if (not _G.AutoFarm and not _G.AutoMaterial and not _G.AutoKillBoss) or currentTargetRoot ~= targetMobRoot or isProcessingQuest then break end
                        if _G.SelectedSkills and _G.SelectedSkills[skill] then
                            local tool = getToolAtSlot(_G.SelectedSlot)
                            actionRemote:FireServer(tool and tool.Name or "Combat", string.lower(skill)) task.wait(skillDelay)
                        end
                    end
                else currentTargetRoot = nil task.wait(0.1) end
            end
            task.wait(0.01)
        end
    end)
end

